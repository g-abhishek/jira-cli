# ─────────────────────────────────────────────
# Jira CLI — Environment Configuration
# Copy this file to ~/.jira-cli/.env and fill in your values
# DO NOT commit this file to git
# ─────────────────────────────────────────────

# Your Atlassian instance URL
JIRA_BASE_URL=https://your-domain.atlassian.net

# Your Atlassian account email
JIRA_EMAIL=your-email@company.com

# Jira API Token — generate at:
# https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your-api-token-here

# ── AI Providers (optional — CLI works without any, AI features disabled) ──────
# Configure one or both. Claude takes priority when both are set (or set AI_PROVIDER to override).

# Anthropic Claude API Key — get at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI (Codex) API Key — get at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# Preferred AI provider: claude | openai | (leave unset for auto-detect)
# AI_PROVIDER=claude

# Default Jira project key (fallback if not detected from git or .jira file)
DEFAULT_PROJECT=JCP

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Cache TTL in seconds (default: 86400 = 24 hours)
CACHE_TTL=86400
